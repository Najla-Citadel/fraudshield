# Database Configuration
POSTGRES_USER=fraudshield
POSTGRES_PASSWORD=generate_a_strong_password_here
POSTGRES_DB=fraudshield

# Redis Configuration
REDIS_PASSWORD=generate_another_strong_password_here

# App Configuration
JWT_SECRET=your_secure_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_secure_refresh_token_secret_here

# Domain for Nginx/SSL
DOMAIN_NAME=api.yourdomain.com
PORT=3000
NODE_ENV=production

# Database URL (used for Prisma migrations on host if needed)
# REPLACE <IP> with localhost if running prisma on droplet host
# connection_limit=10 caps simultaneous DB connections (default is unlimited, which can exhaust pg max_connections=100)
# pool_timeout=20 ensures queries fail-fast after 20s if all connections are busy, instead of hanging indefinitely
DATABASE_URL="postgresql://fraudshield:PASSWORD@localhost:5432/fraudshield?schema=public&connection_limit=10&pool_timeout=20"

# Email Configuration (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_real_smtp_api_key_here
SMTP_FROM="FraudShield <noreply@fraudshieldprotect.com>"
SMTP_SECURE=true

# Firebase
FIREBASE_SERVICE_ACCOUNT=

# Alert Scheduling
# Suggested: 0 * * * * (Every hour), */15 * * * * (Every 15 mins)
TRENDING_ALERT_CRON=0 * * * *
