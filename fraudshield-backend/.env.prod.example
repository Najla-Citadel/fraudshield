# Database Configuration
POSTGRES_USER=fraudshield
POSTGRES_PASSWORD=generate_a_strong_password_here
POSTGRES_DB=fraudshield

# Redis Configuration
REDIS_PASSWORD=generate_another_strong_password_here

# App Configuration
JWT_SECRET=your_secure_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_secure_refresh_token_secret_here

# Domain for Nginx/SSL
DOMAIN_NAME=api.yourdomain.com
PORT=3000
NODE_ENV=production

# Database URL (used for Prisma migrations on host if needed)
# REPLACE <IP> with localhost if running prisma on droplet host
DATABASE_URL="postgresql://fraudshield:PASSWORD@localhost:5432/fraudshield?schema=public"
