generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  passwordHash         String
  fullName             String?
  role                 String               @default("user")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  refreshToken         String?              @unique
  acceptedTermsAt      DateTime?
  acceptedTermsVersion String?
  emailVerified        Boolean              @default(false)
  alerts               Alert[]
  alertSubscription    AlertSubscription?   @relation("UserAlertSubscription")
  auditLogs            AuditLog[]
  comments             Comment[]
  transactions         PointsTransaction[]
  profile              Profile?
  redemptions          Redemption[]
  reports              ScamReport[]
  userTransactions     Transaction[]
  transactionJournals  TransactionJournal[]
  subscriptions        UserSubscription[]
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
  @@index([targetType])
}

model Profile {
  id             String    @id @default(uuid())
  bio            String?
  avatar         String?
  points         Int       @default(0)
  userId         String    @unique
  metadata       Json      @default("{}")
  badges         Json      @default("[]")
  reputation     Int       @default(0)
  lastLoginDate  DateTime?
  loginStreak    Int       @default(0)
  mailingAddress String?
  mobile         String?
  preferredName  String?
  totalPoints    Int       @default(0)
  user           User      @relation(fields: [userId], references: [id])
}

model SubscriptionPlan {
  id            String             @id @default(uuid())
  name          String
  price         Float
  features      String[]
  durationDays  Int
  subscriptions UserSubscription[]
}

model UserSubscription {
  id        String           @id @default(uuid())
  userId    String
  planId    String
  startDate DateTime         @default(now())
  endDate   DateTime
  isActive  Boolean          @default(true)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
}

model ScamReport {
  id            String         @id @default(uuid())
  type          String
  target        String?
  description   String
  userId        String
  status        String         @default("pending")
  createdAt     DateTime       @default(now())
  category      String
  evidence      Json           @default("{}")
  isPublic      Boolean        @default(false)
  latitude      Float?
  longitude     Float?
  targetType    String?
  deletedAt     DateTime?
  comments      Comment[]
  user          User           @relation(fields: [userId], references: [id])
  verifications Verification[]

  @@index([isPublic])
  @@index([createdAt])
  @@index([category])
  @@index([status])
  @@index([target])
  @@index([targetType])
}

model Comment {
  id        String     @id @default(uuid())
  text      String
  userId    String
  reportId  String
  createdAt DateTime   @default(now())
  report    ScamReport @relation(fields: [reportId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@index([reportId])
}

model Verification {
  id        String     @id @default(uuid())
  reportId  String
  userId    String
  isSame    Boolean
  createdAt DateTime   @default(now())
  report    ScamReport @relation(fields: [reportId], references: [id])

  @@unique([reportId, userId])
}

model PointsTransaction {
  id          String   @id @default(uuid())
  amount      Int
  description String
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model BehavioralEvent {
  id        String   @id @default(uuid())
  type      String
  metadata  Json
  userId    String
  createdAt DateTime @default(now())
}

model Alert {
  id          String        @id @default(uuid())
  title       String
  message     String
  type        String        @default("ALERT") // Required for Admin Broadcasts
  isRead      Boolean       @default(false)
  userId      String
  createdAt   DateTime      @default(now())
  txId        String?
  riskScore   Int?
  decision    String?
  actionTaken String?
  category    AlertCategory @default(COMMUNITY)
  metadata    Json          @default("{}")
  severity    AlertSeverity @default(LOW)
  user        User          @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  merchant  String
  decision  String
  riskScore Int
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model FraudLabel {
  id        String   @id @default(uuid())
  txId      String
  label     String
  labeledBy String
  createdAt DateTime @default(now())
}

model Reward {
  id          String       @id @default(uuid())
  name        String
  description String
  pointsCost  Int
  type        String
  metadata    Json         @default("{}")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  isFeatured  Boolean      @default(false)
  minTier     String       @default("BRONZE")
  redemptions Redemption[]
}

model Redemption {
  id         String   @id @default(uuid())
  userId     String
  rewardId   String
  pointsCost Int
  status     String   @default("completed")
  createdAt  DateTime @default(now())
  reward     Reward   @relation(fields: [rewardId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model BadgeDefinition {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String
  icon        String
  tier        String
  trigger     String
  threshold   Int?
  createdAt   DateTime @default(now())
}

model TransactionJournal {
  id            String    @id @default(uuid())
  userId        String
  checkType     CheckType
  target        String?
  riskScore     Int
  status        String
  metadata      Json?
  createdAt     DateTime  @default(now())
  amount        Float?
  merchant      String?
  notes         String?
  paymentMethod String?
  platform      String?
  reportId      String?
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model AlertSubscription {
  id                 String   @id @default(uuid())
  userId             String   @unique
  categories         String[]
  latitude           Float?
  longitude          Float?
  radiusKm           Int      @default(15)
  fcmToken           String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  emailDigestEnabled Boolean  @default(false)
  user               User     @relation("UserAlertSubscription", fields: [userId], references: [id])
}

enum CheckType {
  PHONE
  URL
  BANK
  DOC
  MANUAL
  MSG
  QR
  VOICE
  MACAU_SCAM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertCategory {
  PHISHING
  LOGIN
  SYSTEM_SCAN
  NETWORK
  COMMUNITY
  MACAU_SCAM
}
