generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CheckType {
  PHONE
  URL
  BANK
  DOC
  MANUAL
  auditLogs           AuditLog[]
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
  @@index([targetType])
}

model Profile {
  id       String  @id @default(uuid())
  bio      String?
  avatar   String?
  points     Int     @default(0)
  totalPoints Int     @default(0)
  reputation Int     @default(0)
  badges     Json    @default("[]")
  userId     String  @unique
  metadata   Json    @default("{}")
  lastLoginDate DateTime?
  loginStreak Int     @default(0)
  preferredName  String?
  mobile         String?
  mailingAddress String?
  user     User    @relation(fields: [userId], references: [id])
}

model SubscriptionPlan {
  id            String             @id @default(uuid())
  name          String
  price         Float
  features      String[]
  durationDays  Int
  subscriptions UserSubscription[]
}

model UserSubscription {
  id        String           @id @default(uuid())
  userId    String
  planId    String
  startDate DateTime         @default(now())
  endDate   DateTime
  isActive  Boolean          @default(true)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
}

model ScamReport {
  id          String         @id @default(uuid())
  type        String
  target      String?
  targetType  String?        // e.g. "phone", "bank_account", "url"
  description String
  userId      String
  status      String         @default("pending")
  createdAt   DateTime       @default(now())
  category    String
  evidence    Json           @default("{}")
  isPublic    Boolean        @default(false)
  latitude    Float?
  longitude   Float?
  user        User           @relation(fields: [userId], references: [id])
  verifications Verification[]
  comments    Comment[]
  deletedAt   DateTime?

  @@index([isPublic])
  @@index([createdAt])
  @@index([category])
  @@index([status])
  id          String        @id @default(uuid())
  category    AlertCategory @default(COMMUNITY)
  severity    AlertSeverity @default(LOW)
  title       String
  message     String
  type        String        @default("ALERT") // Required for Admin Broadcasts
  metadata    Json          @default("{}")
  isRead      Boolean       @default(false)
  actionTaken String?
  userId      String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id])

  // Kept for backward compatibility
  txId      String?
  riskScore Int?
  decision  String?
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  merchant  String
  decision  String
  riskScore Int
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model FraudLabel {
  id        String   @id @default(uuid())
  txId      String
  label     String
  labeledBy String
  createdAt DateTime @default(now())
}

model Reward {
  id          String       @id @default(uuid())
  name        String
  description String
  pointsCost  Int
  type        String       // 'subscription', 'badge', 'cosmetic'
  metadata    Json         @default("{}")
  active      Boolean      @default(true)
  minTier     String       @default("BRONZE") // BRONZE, SILVER, GOLD, DIAMOND
  isFeatured  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  redemptions Redemption[]
}

model Redemption {
  id         String   @id @default(uuid())
  userId     String
  rewardId   String
  pointsCost Int
  status     String   @default("completed") // 'pending', 'completed', 'failed'
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  reward     Reward   @relation(fields: [rewardId], references: [id])
}
model BadgeDefinition {
  id          String   @id @default(uuid())
  key         String   @unique   // e.g. "elite_sentinel"
  name        String             // Display name: "Elite Sentinel"
  description String
  icon        String             // Emoji or icon name
  tier        String             // "bronze" | "silver" | "gold" | "platinum"
  trigger     String             // "reputation" | "reports" | "streak" | "purchase"
  threshold   Int?               // e.g. reputation >= 50
  createdAt   DateTime @default(now())
}

model TransactionJournal {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  checkType     CheckType
  target        String?   // the mapped URL/Phone/Num or Recipient
  riskScore     Int      // 0-100 indicating fraud risk
  status        String   // SAFE, SUSPICIOUS, BLOCKED, SCAMMED
  metadata      Json?    // Stores the raw deep-dive data from APIs
  
  // Fields for manual transaction logging
  amount        Float?
  merchant      String?
  paymentMethod String?   // "duitnow", "bank_transfer", etc.
  platform      String?   // "Shopee", "WhatsApp", etc.
  notes         String?
  reportId      String?   // Linked if converted to ScamReport
  
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AlertSubscription {
  id          String   @id @default(uuid())
  userId      String   @unique
  categories  String[]
  latitude    Float?
  longitude   Float?
  radiusKm    Int      @default(15)
  fcmToken    String?
  isActive          Boolean  @default(true)
  emailDigestEnabled Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserAlertSubscription", fields: [userId], references: [id])
}
